generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  subject     String   @default("")
  thumbnail   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  slides      Slide[]
  enrollments Enrollment[]
  sessions    Session[]
  questions   Question[]
  quizzes     Quiz[]
}

model Slide {
  id        String   @id @default(cuid())
  courseId  String
  title     String
  content   String   @default("")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions Question[]
}

model Question {
  id          String   @id @default(cuid())
  courseId    String?
  slideId     String?
  type        String   @default("multiple_choice")
  question    String
  options     String?  // JSON string of string[]
  answer      String
  explanation String?
  difficulty  String   @default("medium")
  concept     String?
  createdAt   DateTime @default(now())
  course      Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  slide       Slide?   @relation(fields: [slideId], references: [id], onDelete: SetNull)
  quizzes     QuizQuestion[]
}

model Quiz {
  id          String   @id @default(cuid())
  courseId    String?
  title       String   @default("Quiz")
  createdAt   DateTime @default(now())
  course      Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  questions   QuizQuestion[]
}

model QuizQuestion {
  id         String   @id @default(cuid())
  quizId     String
  questionId String
  createdAt  DateTime @default(now())
  quiz       Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question   Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  @@unique([quizId, questionId])
}

model Enrollment {
  id        String   @id @default(cuid())
  courseId  String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  @@unique([courseId])
}

model Session {
  id        String   @id @default(cuid())
  courseId  String?
  createdAt DateTime @default(now())
  course    Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
}

// Ephemeral presence of a client instance. Personal learning data lives in the
// user's browser; this table only lets live instances discover each other.
 
model Presence {
  instanceId      String   @id
  displayName     String   @default("")
  avatarGradient  String   @default("from-emerald-400 to-teal-500")
  totalXP          Int      @default(0)
  weeklyXP         Int      @default(0)
  level            Int      @default(1)
  streak           Int      @default(0)
  coursesCompleted Int      @default(0)
  quizAccuracy     Int      @default(0)
  currentTopic     String   @default("")
  lastSeen         DateTime @default(now())
  createdAt        DateTime @default(now())
}

// ─── System Intelligence (UNIFIED-PLAN R2/R3) ──────────────────────────────
// System-level intelligence ONLY — prompt strategies and their effectiveness.
// Never user conversations, never personal learning content (R1).

// Live strategy entries the prompt composer reads. Written ONLY by the
// promotion gate (from ValidatedImprovement) or seed scripts — never by models.
model PromptStrategy {
  id          String   @id @default(cuid())
  // Where it applies: "questions", "chat", "flashcards", "notes", "all"
  scope       String
  // Slot in the composed prompt: "structure", "formatting", "teaching_style",
  // "quality_constraints", "difficulty", "language_policy"
  slot        String
  name        String   @unique
  content     String
  version     Int      @default(1)
  active      Boolean  @default(true)
  // Rolling effectiveness counters (system-level only)
  uses        Int      @default(0)
  passCount   Int      @default(0)
  failCount   Int      @default(0)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
  @@index([scope, slot, active])
}

// Stage 1 (R2): the ONLY table AI output may write to. Suggestions are inert
// until promoted through the code-gated review path.
model AiSuggestion {
  id             String    @id @default(cuid())
  scope          String
  slot           String
  proposal       String
  rationale      String    @default("")
  // Evidence: validator names / pass-rate deltas that motivated it
  evidence       String    @default("")
  targetStrategy String? // PromptStrategy.name it wants to amend, if any
  status         String    @default("pending") // pending | approved | rejected
  reviewedAt     DateTime?
  reviewNote     String    @default("")
  createdAt      DateTime  @default(now())
  @@index([status, scope])
}

// Stage 2 (R2): audit trail of suggestions that passed validation + explicit
// approval. Promotion into PromptStrategy happens from here, by code only.
model ValidatedImprovement {
  id           String   @id @default(cuid())
  suggestionId String   @unique
  scope        String
  slot         String
  content      String
  appliedTo    String // PromptStrategy.name created/updated
  appliedAt    DateTime @default(now())
}

model LearnerProfile {
  id                String   @id @default(cuid())
  learningStyle     String   @default("reading")
  pace              String   @default("steady")
  vocabularySensitive Boolean @default(true)
  prefersStory       Boolean @default(true)
  prefersBigPicture  Boolean @default(false)
  simpleGrammar      Boolean @default(false)
  jargonTolerance    String   @default("medium")
  masteryApproach    String   @default("evidence")
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())
}
